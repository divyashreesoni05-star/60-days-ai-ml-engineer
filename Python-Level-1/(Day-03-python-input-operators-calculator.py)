# Taking input from user
num1 = float(input("Enter first number: "))
num2 = float(input("Enter second number: "))

# Asking user for operator
operator = input("Enter operator (+, -, *, /): ")

# Performing calculation
if operator == "+":
    result = num1 + num2
    print("Result:", result)

elif operator == "-":
    result = num1 - num2
    print("Result:", result)

elif operator == "*":
    result = num1 * num2
    print("Result:", result)

elif operator == "/":
    result = num1 / num2
    print("Result:", result)

else:
    print("Invalid operator")
